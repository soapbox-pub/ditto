{
  "name": "@blobbi/react",
  "version": "0.0.0",
  "description": "Portable, app-agnostic React hooks for Blobbi, built on @blobbi/core.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc -b tsconfig.build.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "peerDependencies": {
    "@blobbi/core": "*",
    "@nostrify/nostrify": "*",
    "@nostrify/react": "*",
    "@tanstack/react-query": "*",
    "react": "*"
  }
}
