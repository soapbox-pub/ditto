{
  "name": "@blobbi/core",
  "version": "0.0.0",
  "description": "Portable, framework-agnostic core domain logic for Blobbi.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "dependencies": {
    "@noble/hashes": "^1.3.1"
  },
  "peerDependencies": {
    "@nostrify/nostrify": "^0.53.0"
  }
}
